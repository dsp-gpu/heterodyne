@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(DspCore             REQUIRED)
find_dependency(DspSpectrum         REQUIRED)
find_dependency(DspSignalGenerators REQUIRED)
find_dependency(hip                 REQUIRED)   # lowercase — Linux case-sensitive!
find_dependency(hipfft              REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/DspHeterodyneTargets.cmake")
check_required_components(DspHeterodyne)
